# Create a copy of this file named .env and fill in the values

# Get your Groq API key from Groq Console: https://console.groq.com/keys
GROQ_API_KEY=

# Get your Serper API key from https://serper.dev
SERPER_API_KEY=

# Email configuration (Gmail)
GMAIL_USER=
# Use an App Password, not your real password: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# The email address to send the report to (can be the same as GMAIL_USER)
TO_EMAIL=
